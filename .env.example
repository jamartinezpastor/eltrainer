# ===== Frontend (build arg en Coolify / Docker) =====
# URL base de la API que usará el navegador
VITE_API_URL=https://api-eltrainer.tudominio.com/api

# ===== Backend (variables de entorno en Coolify) =====
# Clave de firma de los JWT. Generar con: openssl rand -hex 32
SECRET_KEY=cambia-esto-por-una-clave-aleatoria

# Orígenes permitidos por CORS, separados por comas
CORS_ORIGINS=https://eltrainer.tudominio.com

# Ruta de la base de datos SQLite (en Coolify, montar el volumen persistente en /app/data)
DATABASE_URL=sqlite:////app/data/fastrainer.db
